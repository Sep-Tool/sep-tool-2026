    ascend: { en: "I dropped a Medicare Supplement Insurance (Medigap) policy when I first joined a Medicare Advantage Plan. It's been less than 12 months since I left my Medigap policy. I want to switch to Original Medicare so I can go back to my Medigap policy, and I'm joining a Drug Plan (Part D). I dropped on MMDDYYYY:", es: "Cancelé mi póliza de Seguro Suplementario de Medicare (Medigap) al inscribirme por primera vez en un plan Medicare Advantage. Han pasado menos de 12 meses desde que cancelé mi póliza Medigap. Quiero cambiarme a Medicare Original para poder volver a mi póliza Medigap y me inscribiré en un plan de medicamentos (Parte D). Cancelé mi suscripción el MMDDAAAA:" }
  }
];

// ── PLAN MODE ──
let planMode = 'mapd';
let SEPs = MAPDSEPs;


// ─────────────────────────────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────────────────────────────
let currentStep = -1; // -1 = intro, 0..N = SEP questions
let currentLang = 'en';
let pendingYesSEP = null;

// ─────────────────────────────────────────────────────────────────────────────
// RENDER
// ─────────────────────────────────────────────────────────────────────────────
function updateProgress() {
  const lbl = document.getElementById('progressLabel');
  const fill = document.getElementById('progressFill');
  if (currentStep < 0) {
    lbl.textContent = 'Start →';
    fill.style.width = '0%';
  } else {
    const pct = Math.round(((currentStep + 1) / SEPs.length) * 100);
    lbl.textContent = `${currentStep + 1} / ${SEPs.length}`;
    fill.style.width = pct + '%';
  }
}

function render() {
  updateProgress();
  const stage = document.getElementById('stage');

  if (currentStep === -1) {
    renderIntro(stage);
  } else if (currentStep >= SEPs.length) {
    renderNoMatch(stage);
  } else {
    renderQuestion(stage, SEPs[currentStep]);
  }
}

function renderIntro(stage) {
  const esI = currentLang === 'es';
  const planLabel = planMode === 'pdp'
    ? (esI ? 'Herramienta PDP 2026' : '2026 PDP Tool')
    : (esI ? 'Herramienta MA-PD 2026' : '2026 MA-PD Tool');
  const sepCount = SEPs.length;
  stage.innerHTML = `
    <div class="plan-toggle">
      <button class="toggle-btn ${planMode === 'mapd' ? 'active' : ''}" onclick="switchPlan('mapd')">
        ${esI ? 'MA-PD' : 'MA-PD'}
      </button>
      <button class="toggle-btn ${planMode === 'pdp' ? 'active' : ''}" onclick="switchPlan('pdp')">
        ${esI ? 'PDP' : 'PDP'}
      </button>
    </div>
    <div class="headline">
      <h1>${esI ? 'Pregunta hasta recibir un' : 'Ask until you receive a'}<span class="yes"> ${esI ? '¡Sí!' : 'Yes!'}</span></h1>
      <div class="headline-sub">${planLabel}</div>
    </div>
    <div class="intro-card">
      <h2>${esI ? 'Períodos de Elección — Usar en Orden de Prioridad' : 'Election Periods — Use in Order of Priority'}</h2>
      <ul class="priority-list">
        <li>
          <div class="p-num">1</div>
          <div class="p-text"><strong>${esI ? 'ICEP – Período de Elección de Cobertura Inicial' : 'ICEP – Initial Coverage Election Period'}</strong><span>${esI ? 'Nuevo en Medicare' : 'New to Medicare'}</span></div>
        </li>
        <li>
          <div class="p-num">2</div>
          <div class="p-text"><strong>${esI ? 'OEP – Período de Inscripción Abierta' : 'OEP – Open Enrollment Period'}</strong><span>${esI ? 'Válido solo del 1 de enero al 31 de marzo' : 'Valid January 1 – March 31 only'}</span></div>
        </li>
        <li>
          <div class="p-num">3</div>
          <div class="p-text"><strong>${esI ? 'SEPs – Períodos de Inscripción Especial' : 'SEPs – Special Enrollment Periods'}</strong><span>${esI ? 'Haga las 33 preguntas a continuación en orden' : 'Ask all 33 questions below in order'}</span></div>
        </li>
        <li>
          <div class="p-num">4</div>
          <div class="p-text"><strong>${esI ? 'AEP – Período de Inscripción Anual' : 'AEP – Annual Enrollment Period'}</strong><span>${esI ? 'Del 15 de octubre al 7 de diciembre de cada año' : 'October 15 – December 7 each year'}</span></div>
        </li>
      </ul>
      <div class="script-block">
        ${esI
          ? `"Señor/Señora, le voy a hacer varias preguntas para determinar si puedo ayudarle a inscribirse hoy. Después del Período de Inscripción Anual, que va del 15 de octubre al 7 de diciembre, muchas personas no pueden cambiar su plan — pero algunas sí pueden. Las preguntas pueden parecer un poco extrañas, pero si la respuesta es 'Sí' a cualquiera de estas preguntas, podemos inscribirle hoy."`
          : `"Sir/Ma'am, I am going to ask you quite a few questions to allow me to determine if I can help you enroll today. After the Annual Enrollment Period which runs from October 15th through December 7th, many people cannot change their plan — but some can. The questions may sound a little strange, but if the answer is 'Yes' to any one of these questions, we can enroll you today."`
        }
      </div>
      <button class="btn-start" onclick="startQuestions()">${esI ? 'Iniciar Preguntas SEP →' : 'Begin SEP Questions →'}</button>
      <button class="index-toggle-btn" onclick="openSepIndex()">📋 ${esI ? 'Preguntas SEP' : 'SEP Questions'}</button>
    </div>
  `;
}

function renderQuestion(stage, sep) {
  const qText = sep.q[currentLang] || sep.q.en;
  stage.innerHTML = `
    <div class="headline">
      <h1>Ask until you receive a<span class="yes"> Yes!</span></h1>
    </div>
    <div class="question-card card-relative">
      <div class="wc-logo"><span>Well<br>Care</span></div>
      <div class="question-num">SEP Question ${sep.num} of ${SEPs.length}</div>
      <div class="question-text">${sep.num}.) &nbsp;${qText}</div>
      <div class="btn-row">
        <button class="btn-yes" onclick="handleAnswer(true)">Yes</button>
        <button class="btn-no" onclick="handleAnswer(false)">No</button>
      </div>
    </div>
    <div class="nav-bar">
      <button class="btn-nav" onclick="goBack()" ${currentStep === 0 ? 'disabled' : ''}>◀ BACK</button>
      <button class="btn-nav" onclick="openSepIndex()" style="background:#00a89d;color:white;">📋 INDEX</button>
      <button class="btn-nav btn-restart" onclick="restart()">↺ RESTART</button>
    </div>
  `;
}

function renderDetail(stage, sep) {
  const ruleText = (sep.rule[currentLang] || sep.rule.en)
    .replace(/\\n/g, '<br>')
    .replace(/<red>(.*?)<\/red>/gs, '<span class="rule-red">$1</span>');
  const ascendText = sep.ascend ? (sep.ascend[currentLang] || sep.ascend.en) : null;

  const esD = currentLang === 'es';

  // Timeframe box (SEP 8 and any future SEP with timeframe data)
  let timeframeHTML = '';
  if (sep.reminder && sep.reminder.timeframe) {
    const tfItems = (esD && sep.reminder.timeframeEs) ? sep.reminder.timeframeEs : sep.reminder.timeframe;
    const tfLabel = esD ? '⏱️ Plazos del SEP' : '⏱️ SEP Timeframes';
    timeframeHTML = `
      <div class="timeframe-box">
        <div class="timeframe-header">${tfLabel}</div>
        <div class="timeframe-body">
          ${tfItems.map(item => {
            // Strip leading emoji prefix for cleaner display
            const clean = item.replace(/^⏱️\s*/,'').replace(/^⚠️\s*/,'').replace(/^📋\s*/,'');
            const icon = item.startsWith('⏱️') ? '⏱️' : item.startsWith('⚠️') ? '⚠️' : '📋';
            return `<div class="tf-item"><span class="tf-icon">${icon}</span><span>${clean}</span></div>`;
          }).join('')}
        </div>
      </div>`;
  }

  stage.innerHTML = `
    <div class="headline">
      <h1>✅ SEP ${sep.num} ${esD ? '¡Aplica!' : 'Applies!'}</h1>
    </div>
    <div class="detail-card card-relative">
      <div class="wc-logo"><span>Well<br>Care</span></div>
      ${sep.noteRed ? `<div class="detail-note">⚠️ ${sep.noteRed}</div>` : ''}
      <div class="detail-rule">${ruleText}</div>
      ${ascendText ? `
      <div class="ascend-block">
        <span class="ascend-label">${esD ? 'SELECCIÓN EN APLICACIÓN ASCEND:' : 'ASCEND APPLICATION SELECTION:'}</span>
        <div class="ascend-quote">${ascendText}</div>
      </div>` : ''}
    </div>
    ${timeframeHTML}
    <div class="nav-bar">
      <button class="btn-nav" onclick="backToQuestion()">◀ ${esD ? 'REGRESAR' : 'BACK'}</button>
      <button class="btn-nav btn-restart" onclick="restart()">↺ ${esD ? 'REINICIAR' : 'RESTART'}</button>
    </div>
  `;
}

function renderNoMatch(stage) {
  const esNM = currentLang === 'es';
  stage.innerHTML = `
    <div class="headline">
      <h1>${esNM ? 'Pregunta hasta recibir un' : 'Ask until you receive a'}<span class="yes"> ${esNM ? '¡Sí!' : 'Yes!'}</span></h1>
    </div>
    <div class="result-card">
      <div class="result-icon">📋</div>
      <h2>${esNM ? 'Ningún SEP Encontrado' : 'No SEP Found'}</h2>
      <p>${esNM ? 'El beneficiario no calificó para ningún Período de Inscripción Especial en este momento. Por favor, infórmele que espere el Período de Inscripción Anual (15 de octubre – 7 de diciembre) o consulte con un supervisor para los siguientes pasos.' : 'The beneficiary did not qualify for any Special Enrollment Period at this time. Please advise them to wait for the Annual Enrollment Period (October 15 – December 7) or consult a supervisor for next steps.'}</p>
      <br>
      <button class="btn-start" onclick="restart()">↺ ${esNM ? 'Comenzar de Nuevo' : 'Start Over'}</button>
    </div>
  `;
}

// ─────────────────────────────────────────────────────────────────────────────
// MODAL
// ─────────────────────────────────────────────────────────────────────────────
function showReminder(sep) {
  const r = sep.reminder;
  const es = currentLang === 'es';
  const title = es && r.titleEs ? r.titleEs : r.title;
  const intro = es && r.introEs ? r.introEs : r.intro;
  const criteria = es && r.criteriaEs ? r.criteriaEs : r.criteria;
  const dos = es && r.dosEs ? r.dosEs : r.dos;
  const donts = es && r.dontsEs ? r.dontsEs : r.donts;
  const criteriaLabel = es ? 'Este SEP aplica si el beneficiario:' : 'This SEP applies if the beneficiary:';
  const doLabel = es ? 'Lo que se DEBE Hacer' : 'What to DO';
  const dontLabel = es ? 'Lo que NO se debe Hacer' : 'What NOT to DO';

  document.getElementById('modalSubtitle').textContent = ` — ${title}`;
  document.getElementById('modalHeaderLabel').textContent = es ? 'Recordatorio para Agentes' : 'Agent Reminder';

  let html = `<div class="modal-intro">${intro.replace(/\n/g, '<br>')}</div>`;

  if (criteria && criteria.length) {
    html += `<div class="modal-criteria"><p>${criteriaLabel}</p><ul>`;
    criteria.forEach(c => { html += `<li>${c}</li>`; });
    html += `</ul></div>`;
  }

  html += `<div class="dos-donts-grid">
    <div class="dos-box">
      <h3>${doLabel}</h3>
      ${dos.map(d => `<div class="item">${d}</div>`).join('')}
    </div>
    <div class="donts-box">
      <h3>${dontLabel}</h3>
      ${donts.map(d => `<div class="item">${d}</div>`).join('')}
    </div>
  </div>`;

  document.getElementById('modalBody').innerHTML = html;
  const contBtn = document.getElementById('modalContinueBtn');
  if (contBtn) contBtn.textContent = es ? 'Ver Detalles del SEP →' : 'View SEP Details →';
  document.getElementById('reminderModal').classList.remove('hidden');
  document.querySelector('.modal-box').scrollTop = 0;
  pendingYesSEP = sep;
}

function closeModal() {
  const btn = document.getElementById('modalContinueBtn');
  if (btn) btn.textContent = currentLang === 'es' ? 'Ver Detalles del SEP →' : 'View SEP Details →';
  document.getElementById('reminderModal').classList.add('hidden');
  if (pendingYesSEP) {
    renderDetail(document.getElementById('stage'), pendingYesSEP);
    pendingYesSEP = null;
  }
}

// Click outside modal to close
document.getElementById('reminderModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// ─────────────────────────────────────────────────────────────────────────────
// NAVIGATION
// ─────────────────────────────────────────────────────────────────────────────
function startQuestions() {
  currentStep = 0;
  render();
}

function handleAnswer(yes) {
  if (yes) {
    const sep = SEPs[currentStep];
    if (sep.hasReminder) {
      // Show Agent Reminder popup first, then detail on dismiss
      showReminder(sep);
    } else {
      // Go straight to detail screen
      renderDetail(document.getElementById('stage'), sep);
    }
  } else {
    currentStep++;
    render();
  }
}

function goBack() {
  if (currentStep > 0) currentStep--;
  else currentStep = -1;
  render();
}

function backToQuestion() {
  render();
}

function switchPlan(mode) {
  if (mode === planMode) return;
  planMode = mode;
  SEPs = planMode === 'pdp' ? PDPSEPs : MAPDSEPs;
  currentStep = -1;
  render();
  window.scrollTo(0, 0);
}

function restart() {
  currentStep = -1;
  pendingYesSEP = null;
  document.getElementById('reminderModal').classList.add('hidden');
  render();
}

function setLang(lang, btn) {
  currentLang = lang;
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}


// ─────────────────────────────────────────────────────────────────────────────
// SEP INDEX
// ─────────────────────────────────────────────────────────────────────────────

function buildSepIndexList(filter) {
  const list = document.getElementById('sepIndexList');
  const q = (filter || '').toLowerCase();
  list.innerHTML = '';

  SEPs.forEach((sep, idx) => {
    const qText = sep.q[currentLang] || sep.q.en;
    if (q && !qText.toLowerCase().includes(q) && !String(sep.num).includes(q)) return;

    const item = document.createElement('div');
    item.className = 'sep-index-item' + (sep.hasReminder ? ' sep-idx-has-reminder' : '');
    item.innerHTML = `
      <div class="sep-idx-num">${sep.num}</div>
      <div class="sep-idx-text">${qText}</div>
      ${sep.hasReminder ? '<span class="sep-idx-badge">⚠️ Reminder</span>' : ''}
      <span class="sep-idx-arrow">›</span>
    `;
    item.onclick = () => jumpToSep(idx);
    list.appendChild(item);
  });

  if (list.children.length === 0) {
    list.innerHTML = '<div style="padding:20px;text-align:center;color:#999;">No matching SEPs found</div>';
  }
}

function openSepIndex() {
  const esIdx = currentLang === 'es';
  const t = document.getElementById('sepIndexTitle');
  const s = document.getElementById('sepIndexSub');
  const inp = document.getElementById('sepIndexSearchInput');
  const leg = document.getElementById('sepIndexLegend');
  if (t) t.textContent = esIdx ? '📋 Preguntas SEP' : '📋 SEP Questions';
  const planLbl = planMode === 'pdp' ? 'PDP' : 'MA-PD';
  if (s) s.textContent = esIdx ? `Haz clic en cualquier SEP para ir directamente a esa pregunta (${planLbl})` : `Click any SEP to jump directly to that question (${planLbl})`;
  if (inp) inp.placeholder = esIdx ? '🔍  Buscar preguntas SEP...' : '🔍  Search SEP questions...';
  if (leg) leg.textContent = esIdx ? '🟠 Naranja = Se requiere popup de Recordatorio para Agentes antes de ver detalles' : '🟠 Orange = Agent Reminder popup required before viewing details';
  document.getElementById('sepIndexSearch').value = '';
  buildSepIndexList('');
  document.getElementById('sepIndexModal').classList.remove('hidden');
}

function closeSepIndex() {
  document.getElementById('sepIndexModal').classList.add('hidden');
}

function filterSepIndex(val) {
  buildSepIndexList(val);
}

function jumpToSep(idx) {
  closeSepIndex();
  currentStep = idx;
  render();
  window.scrollTo(0, 0);
}

// Click outside index to close
document.getElementById('sepIndexModal').addEventListener('click', function(e) {
  if (e.target === this) closeSepIndex();
});

// INIT
render();
</script>
</body>
</html>
