<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>2026 MAPD SEP Tool – WellCare</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --teal: #00A89D;
    --teal-dark: #007F76;
    --teal-light: #B2E4E1;
    --teal-bg: #E5F7F6;
    --white: #ffffff;
    --text: #1a1a1a;
    --text-mid: #444;
    --text-light: #777;
    --green-bg: #d4edda;
    --green-border: #a3d4ab;
    --red-bg: #fde8e8;
    --red-border: #f5b8b8;
    --red-text: #c0392b;
    --shadow: 0 8px 40px rgba(0,168,157,0.18);
    --shadow-md: 0 4px 20px rgba(0,0,0,0.12);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Open Sans', sans-serif;
    background: linear-gradient(160deg, #00c6bb 0%, #00a89d 40%, #4dd9d0 100%);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── HEADER ── */
  .topbar {
    width: 100%;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255,255,255,0.2);
    position: sticky;
    top: 0;
    z-index: 200;
  }

  .topbar-brand {
    font-family: 'Nunito', sans-serif;
    font-size: 26px;
    font-weight: 900;
    color: white;
    letter-spacing: -1px;
  }

  .topbar-brand span { color: rgba(255,255,255,0.7); font-size: 14px; font-weight: 700; margin-left: 10px; letter-spacing: 0; }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .lang-toggle {
    display: flex;
    background: rgba(255,255,255,0.2);
    border-radius: 8px;
    overflow: hidden;
  }

  .lang-btn {
    padding: 6px 16px;
    border: none;
    background: transparent;
    color: white;
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .lang-btn.active { background: white; color: var(--teal); }

  .progress-bar-wrap {
    background: rgba(255,255,255,0.25);
    border-radius: 10px;
    height: 8px;
    width: 160px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: white;
    border-radius: 10px;
    transition: width 0.4s ease;
  }

  .progress-label {
    color: white;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }

  /* ── MAIN STAGE ── */
  .stage {
    flex: 1;
    width: 100%;
    max-width: 820px;
    padding: 40px 20px 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }


  /* ── PLAN TOGGLE ── */
  .plan-toggle {
    display: flex;
    gap: 0;
    background: #e0f5f4;
    border-radius: 50px;
    padding: 4px;
    box-shadow: 0 2px 8px rgba(0,168,157,0.15);
    margin-bottom: 4px;
  }
  .toggle-btn {
    flex: 1;
    padding: 10px 32px;
    border: none;
    border-radius: 50px;
    font-family: 'Nunito', sans-serif;
    font-size: 15px;
    font-weight: 800;
    cursor: pointer;
    transition: all 0.22s ease;
    color: #666;
    background: transparent;
    letter-spacing: 0.3px;
  }
  .toggle-btn.active {
    background: var(--teal);
    color: white;
    box-shadow: 0 3px 12px rgba(0,168,157,0.35);
  }
  .toggle-btn:not(.active):hover {
    background: rgba(0,168,157,0.12);
    color: var(--teal);
  }

  /* ── HEADLINE ── */
  .headline {
    text-align: center;
    animation: fadeUp 0.5s ease;
  }

  .headline h1 {
    font-family: 'Nunito', sans-serif;
    font-size: 52px;
    font-weight: 900;
    color: white;
    text-shadow: 2px 3px 0px rgba(0,0,0,0.15);
    line-height: 1.1;
    letter-spacing: -1px;
  }

  .headline h1 .yes {
    color: #1a1a1a;
    -webkit-text-stroke: 2px white;
    font-size: 62px;
  }

  .headline-sub {
    font-size: 15px;
    color: rgba(255,255,255,0.85);
    margin-top: 6px;
    font-weight: 600;
  }

  /* ── QUESTION CARD ── */
  .question-card {
    background: white;
    border-radius: 28px;
    padding: 44px 48px;
    width: 100%;
    box-shadow: var(--shadow);
    text-align: center;
    animation: popIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .question-num {
    display: inline-block;
    background: var(--teal-bg);
    color: var(--teal-dark);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 18px;
    font-family: 'Nunito', sans-serif;
  }

  .question-text {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.5;
    margin-bottom: 36px;
    font-family: 'Open Sans', sans-serif;
  }

  .btn-row {
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .btn-yes, .btn-no {
    padding: 16px 52px;
    border-radius: 12px;
    border: none;
    font-family: 'Nunito', sans-serif;
    font-size: 20px;
    font-weight: 900;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    letter-spacing: 0.5px;
  }

  .btn-yes {
    background: #555;
    color: white;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }

  .btn-no {
    background: #555;
    color: white;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }

  .btn-yes:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,168,157,0.4); background: var(--teal); }
  .btn-no:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); background: #333; }

  /* ── NAV BUTTONS ── */
  .nav-bar {
    display: flex;
    justify-content: space-between;
    width: 100%;
    margin-top: 4px;
  }

  .btn-nav {
    background: var(--teal-dark);
    color: white;
    border: none;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 15px;
    padding: 12px 28px;
    border-radius: 10px;
    cursor: pointer;
    letter-spacing: 1px;
    transition: background 0.2s, transform 0.15s;
    text-transform: uppercase;
  }

  .btn-nav:hover { background: #005e58; transform: translateY(-1px); }
  .btn-nav:disabled { opacity: 0.4; cursor: default; transform: none; }

  .btn-restart {
    background: var(--teal-dark);
  }

  /* ── AGENT REMINDER POPUP ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,100,95,0.55);
    backdrop-filter: blur(6px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: fadeIn 0.2s ease;
  }

  .modal-overlay.hidden { display: none; }

  .modal-box {
    background: white;
    border-radius: 20px;
    max-width: 760px;
    width: 100%;
    max-height: 88vh;
    overflow-y: auto;
    box-shadow: 0 20px 80px rgba(0,0,0,0.4);
    animation: popIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .modal-header {
    background: var(--teal);
    padding: 18px 28px;
    border-radius: 20px 20px 0 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .modal-header-icon {
    width: 36px;
    height: 36px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .modal-header h2 {
    font-family: 'Nunito', sans-serif;
    font-size: 20px;
    font-weight: 900;
    color: white;
    letter-spacing: -0.3px;
  }

  .modal-header h2 span {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0;
  }

  .modal-body {
    padding: 24px 28px;
  }

  .modal-intro {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.75;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid #eee;
  }

  .modal-intro strong { color: var(--text); }

  .modal-criteria {
    margin-bottom: 20px;
  }

  .modal-criteria p {
    font-size: 13.5px;
    color: var(--text-mid);
    margin-bottom: 4px;
    font-weight: 700;
  }

  .modal-criteria ul {
    list-style: none;
    margin-bottom: 8px;
  }

  .modal-criteria ul li {
    font-size: 13.5px;
    color: var(--text-mid);
    padding: 3px 0 3px 20px;
    position: relative;
    line-height: 1.6;
  }

  .modal-criteria ul li::before {
    content: '•';
    position: absolute;
    left: 6px;
    color: var(--teal);
    font-weight: 900;
  }

  .modal-criteria .warn {
    font-size: 13px;
    color: var(--text-mid);
    font-style: italic;
    margin-top: 4px;
  }

  .dos-donts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .dos-box, .donts-box {
    border-radius: 12px;
    padding: 16px;
  }

  .dos-box {
    background: var(--green-bg);
    border: 1.5px solid var(--green-border);
  }

  .donts-box {
    background: var(--red-bg);
    border: 1.5px solid var(--red-border);
  }

  .dos-box h3, .donts-box h3 {
    font-family: 'Nunito', sans-serif;
    font-size: 15px;
    font-weight: 900;
    text-decoration: underline;
    margin-bottom: 12px;
    text-align: center;
  }

  .dos-box h3 { color: #2d6a4f; }
  .donts-box h3 { color: var(--red-text); }

  .dos-box .item, .donts-box .item {
    font-size: 13px;
    line-height: 1.6;
    margin-bottom: 10px;
    color: #333;
  }

  .dos-box .item:last-child, .donts-box .item:last-child { margin-bottom: 0; }

  .item-icon { flex-shrink: 0; font-size: 14px; margin-top: 1px; }

  .dos-box .item em { font-style: italic; }

  .modal-footer {
    padding: 0 28px 24px;
    display: flex;
    justify-content: flex-end;
  }

  .btn-continue {
    background: var(--teal);
    color: white;
    border: none;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 16px;
    padding: 14px 36px;
    border-radius: 12px;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: background 0.2s, transform 0.15s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .btn-continue:hover { background: var(--teal-dark); transform: translateY(-1px); }

  /* ── SEP DETAIL CARD ── */
  .detail-card {
    background: white;
    border-radius: 20px;
    padding: 32px 36px;
    width: 100%;
    box-shadow: var(--shadow);
    animation: popIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .detail-note {
    color: var(--red-text);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.65;
    margin-bottom: 18px;
    padding: 12px 16px;
    background: #fff5f5;
    border-left: 4px solid var(--red-text);
    border-radius: 0 8px 8px 0;
  }

  .rule-red { color: #c0392b; font-weight: 700; }
  .detail-rule {
    font-size: 14.5px;
    color: var(--text-mid);
    line-height: 1.8;
    margin-bottom: 20px;
    white-space: pre-wrap;
  }

  .ascend-block {
    background: #f0faf9;
    border: 1.5px solid var(--teal-light);
    border-radius: 12px;
    padding: 16px 20px;
    text-align: center;
  }

  .ascend-label {
    font-family: 'Nunito', sans-serif;
    font-size: 13px;
    font-weight: 900;
    color: var(--red-text);
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 8px;
  }

  .ascend-quote {
    font-size: 14.5px;
    color: var(--red-text);
    font-style: italic;
    font-weight: 600;
    line-height: 1.7;
  }

  /* ── TIMEFRAME BOX (SEP 8) ── */
  .timeframe-box {
    background: white;
    border: 2px solid var(--teal);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow);
    margin-top: 0;
  }
  .timeframe-header {
    background: var(--teal);
    color: white;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 15px;
    padding: 10px 20px;
    letter-spacing: 0.3px;
  }
  .timeframe-body {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tf-item {
    display: flex;
    gap: 10px;
    font-size: 14px;
    line-height: 1.55;
    color: #333;
  }
  .tf-icon {
    flex-shrink: 0;
    font-size: 16px;
    margin-top: 1px;
  }

  /* ── SUCCESS / NO MATCH ── */
  .result-card {
    background: white;
    border-radius: 24px;
    padding: 48px 40px;
    text-align: center;
    width: 100%;
    box-shadow: var(--shadow);
    animation: popIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .result-icon { font-size: 56px; margin-bottom: 16px; }

  .result-card h2 {
    font-family: 'Nunito', sans-serif;
    font-size: 28px;
    font-weight: 900;
    color: var(--teal-dark);
    margin-bottom: 12px;
  }

  .result-card p {
    font-size: 16px;
    color: var(--text-mid);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── PRIORITY INTRO ── */
  .intro-card {
    background: white;
    border-radius: 24px;
    padding: 36px 40px;
    width: 100%;
    box-shadow: var(--shadow);
    animation: fadeUp 0.4s ease;
  }

  .intro-card h2 {
    font-family: 'Nunito', sans-serif;
    font-size: 22px;
    font-weight: 900;
    color: var(--teal-dark);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--teal-bg);
  }

  .priority-list { list-style: none; }

  .priority-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: 15px;
    color: var(--text-mid);
  }

  .priority-list li:last-child { border-bottom: none; }

  .p-num {
    background: var(--teal);
    color: white;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 15px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .p-text strong { display: block; color: var(--text); font-size: 15px; }
  .p-text span { font-size: 13px; color: var(--text-light); }

  .script-block {
    background: #fffbf0;
    border-left: 4px solid #f5a623;
    border-radius: 0 10px 10px 0;
    padding: 16px 20px;
    margin-top: 24px;
    font-size: 14px;
    font-style: italic;
    color: var(--text-mid);
    line-height: 1.8;
  }

  .script-block::before {
    content: '🎙️ AGENT SCRIPT';
    display: block;
    font-style: normal;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 11px;
    letter-spacing: 2px;
    color: #f5a623;
    margin-bottom: 8px;
  }

  .btn-start {
    background: var(--teal);
    color: white;
    border: none;
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 18px;
    padding: 16px 48px;
    border-radius: 14px;
    cursor: pointer;
    margin-top: 28px;
    width: 100%;
    letter-spacing: 0.5px;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-start:hover { background: var(--teal-dark); transform: translateY(-2px); }

  /* ── OEP CHECK ── */
  .oep-card {
    background: white;
    border-radius: 24px;
    padding: 40px 44px;
    width: 100%;
    text-align: center;
    box-shadow: var(--shadow);
    animation: popIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .oep-badge {
    display: inline-block;
    background: var(--teal-bg);
    color: var(--teal-dark);
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ── DECORATIVE CIRCLES ── */
  .bg-circle {
    position: fixed;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    pointer-events: none;
  }

  .bg-circle.c1 { width: 500px; height: 500px; top: -180px; left: -140px; }
  .bg-circle.c2 { width: 300px; height: 300px; bottom: -80px; right: -60px; }
  .bg-circle.c3 { width: 150px; height: 150px; top: 30%; right: 5%; }

  /* Wellcare logo circle */
  .wc-logo {
    position: absolute;
    top: 10px;
    right: 16px;
    background: var(--teal);
    border-radius: 50%;
    width: 70px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  .wc-logo span {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    color: white;
    font-size: 11px;
    text-align: center;
    line-height: 1.2;
    letter-spacing: -0.2px;
  }

  .card-relative { position: relative; }

  /* Mobile */
  @media (max-width: 600px) {
    .question-text { font-size: 18px; }
    .question-card { padding: 28px 24px; }
    .headline h1 { font-size: 36px; }
    .headline h1 .yes { font-size: 46px; }
    .dos-donts-grid { grid-template-columns: 1fr; }
    .modal-body { padding: 18px; }
    .detail-card { padding: 24px 20px; }
    .intro-card { padding: 28px 20px; }
  }

  /* ── SEP INDEX ── */
  .index-toggle-btn {
    display: block;
    width: 100%;
    max-width: 540px;
    margin: 12px auto 0;
    padding: 13px 20px;
    background: white;
    border: 2px solid var(--teal);
    border-radius: 12px;
    color: var(--teal);
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }
  .index-toggle-btn:hover { background: var(--teal); color: white; }

  .sep-index-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 9998;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 20px 16px;
    overflow-y: auto;
  }
  .sep-index-overlay.hidden { display: none; }

  .sep-index-box {
    background: white;
    border-radius: 20px;
    width: 100%;
    max-width: 680px;
    box-shadow: 0 20px 80px rgba(0,0,0,0.3);
    overflow: hidden;
    margin: auto;
    animation: popIn 0.35s cubic-bezier(0.34,1.56,0.64,1);
  }

  .sep-index-header {
    background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sep-index-header h2 {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 20px;
    color: white;
    margin: 0;
  }
  .sep-index-header p {
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    margin: 4px 0 0;
  }
  .sep-index-close {
    background: rgba(255,255,255,0.2);
    border: none;
    border-radius: 50%;
    width: 36px; height: 36px;
    color: white;
    font-size: 20px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .sep-index-close:hover { background: rgba(255,255,255,0.35); }

